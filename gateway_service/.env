# ==========================================
# STRATEGY OS - GATEWAY SERVICE (.env)
# ==========================================

# 1. Google Cloud Configuration
# The ID of your GCP project (found in the GCP console URL or dashboard)
GOOGLE_CLOUD_PROJECT="your-gcp-project-id"

# 2. Pub/Sub Configuration
# The exact name of the topic you created in GCP Pub/Sub
PUBSUB_TOPIC_ID="incoming-strategy-tasks"

# 3. Local Authentication (ONLY FOR LOCAL TESTING)
# When running locally, GCP needs to know who you are. 
# Download a Service Account JSON key from GCP and put the absolute path here.
# NOTE: You do NOT need this variable when deployed to Cloud Run, 
# as Cloud Run handles identity automatically.
GOOGLE_APPLICATION_CREDENTIALS="/absolute/path/to/your/gcp-service-account-key.json"
