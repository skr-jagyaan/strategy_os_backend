const InteractiveWorksheet = ({ id, title, description, questions }) => {
  const [answers, setAnswers] = useState({});

  useEffect(() => {
    const saved = localStorage.getItem(`worksheet-sp-${id}`);
    if (saved) {
      setAnswers(JSON.parse(saved));
    }
  }, [id]);

  const handleChange = (qIndex, value) => {
