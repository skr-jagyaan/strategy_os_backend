            </label>
            <textarea 
              className="w-full bg-white dark:bg-slate-900 border border-slate-300 dark:border-slate-600 rounded-lg p-4 text-slate-800 dark:text-slate-200 focus:ring-2 focus:ring-amber-500 focus:border-amber-500 transition-all outline-none resize-y min-h-[80px]"
              placeholder="Type your honest assessment here... (Progress autosaves)"
              value={answers[idx] || ''}
              onChange={(e) => handleChange(idx, e.target.value)}
            />
          </div>
        ))}
      </div>
      
      <div className="mt-6 flex justify-end">
        <span className="text-xs text-slate-400 flex items-center gap-1">
          <CheckCircle2 size={12}/> Automatically saved to your browser
        </span>
      </div>
    </div>
  );
};


// --- MAIN APP COMPONENT ---

export default function App() {
  const [currentChapterIdx, setCurrentChapterIdx] = useState(0);
  const [sidebarOpen, setSidebarOpen] = useState(false);
  const [theme, setTheme] = useState('light');

  useEffect(() => {
    const savedChapter = localStorage.getItem('ebook-wg-progress');
    if (savedChapter) setCurrentChapterIdx(parseInt(savedChapter, 10));
    
    const savedTheme = localStorage.getItem('ebook-wg-theme');
    if (savedTheme) {
      setTheme(savedTheme);
      if (savedTheme === 'dark') document.documentElement.classList.add('dark');
    } else if (window.matchMedia && window.matchMedia('(prefers-color-scheme: dark)').matches) {
      setTheme('dark');
      document.documentElement.classList.add('dark');
    }
  }, []);

  const toggleTheme = () => {
    const newTheme = theme === 'light' ? 'dark' : 'light';
    setTheme(newTheme);
    localStorage.setItem('ebook-wg-theme', newTheme);
    if (newTheme === 'dark') {
      document.documentElement.classList.add('dark');
    } else {
      document.documentElement.classList.remove('dark');
    }
  };

  const goToChapter = (idx) => {
    setCurrentChapterIdx(idx);
    localStorage.setItem('ebook-wg-progress', idx.toString());
    setSidebarOpen(false);
    window.scrollTo(0, 0);
  };

  const chapter = bookData[currentChapterIdx];
  const progress = ((currentChapterIdx) / (bookData.length - 1)) * 100;

  if (chapter.type === 'cover') {
    return <CoverPage onStart={() => goToChapter(1)} />;
  }

  return (
    <div className={`min-h-screen flex transition-colors duration-300 ${theme === 'dark' ? 'bg-slate-900 text-slate-300' : 'bg-white text-slate-800'}`}>
      
      {sidebarOpen && (
        <div 
          className="fixed inset-0 bg-black/50 z-40 lg:hidden"
          onClick={() => setSidebarOpen(false)}
        />
      )}

      <aside className={`fixed lg:sticky top-0 h-screen w-80 bg-slate-100 dark:bg-slate-950 border-r border-slate-200 dark:border-slate-800 z-50 transition-transform duration-300 flex flex-col ${sidebarOpen ? 'translate-x-0' : '-translate-x-full lg:translate-x-0'}`}>
        <div className="p-6 border-b border-slate-200 dark:border-slate-800 flex justify-between items-center">
          <div>
            <h2 className="font-bold text-lg text-slate-900 dark:text-white leading-tight font-serif">Why Great Manufacturers<br/>Stay Invisible</h2>
            <p className="text-xs text-amber-600 dark:text-amber-500 mt-1 uppercase tracking-widest font-semibold">Strategic Design</p>
          </div>
          <button onClick={() => setSidebarOpen(false)} className="lg:hidden p-2 text-slate-500">
            <X size={20} />
          </button>
        </div>
        
        <div className="flex-1 overflow-y-auto p-4 space-y-1">
          {bookData.map((item, idx) => {
            if (item.type === 'cover') return null;
            const isActive = idx === currentChapterIdx;
            return (
              <button
                key={item.id}
                onClick={() => goToChapter(idx)}
                className={`w-full text-left px-4 py-3 rounded-lg text-sm font-medium transition-colors ${
                  isActive 
                    ? 'bg-amber-500/10 text-amber-700 dark:text-amber-400' 
                    : 'text-slate-600 dark:text-slate-400 hover:bg-slate-200 dark:hover:bg-slate-800 hover:text-slate-900 dark:hover:text-white'
                }`}
              >
                {item.title}
              </button>
            );
          })}
        </div>

        <div className="p-6 border-t border-slate-200 dark:border-slate-800">
          <div className="text-xs font-semibold text-slate-400 mb-2 uppercase tracking-wider">Reading Progress</div>
          <div className="h-1.5 w-full bg-slate-200 dark:bg-slate-800 rounded-full overflow-hidden">
            <div className="h-full bg-amber-500 transition-all duration-500" style={{ width: `${progress}%` }}></div>
          </div>
          <div className="mt-2 text-xs text-right text-slate-500">{Math.round(progress)}% Complete</div>
        </div>
      </aside>

      <main className="flex-1 min-w-0 flex flex-col h-screen overflow-hidden">
        <header className="flex-none h-16 border-b border-slate-200 dark:border-slate-800 bg-white/80 dark:bg-slate-900/80 backdrop-blur-md sticky top-0 z-30 flex items-center justify-between px-4 lg:px-8">
          <div className="flex items-center gap-4">
            <button 
              onClick={() => setSidebarOpen(true)}
              className="lg:hidden p-2 -ml-2 text-slate-500 hover:text-slate-900 dark:hover:text-white"
            >
              <Menu size={24} />
            </button>
            <div className="hidden md:block text-sm font-medium text-slate-500">
              {chapter.title}
            </div>
          </div>
          
          <button 
            onClick={toggleTheme}
            className="p-2 text-slate-500 hover:text-slate-900 dark:hover:text-white rounded-full hover:bg-slate-100 dark:hover:bg-slate-800 transition-colors"
          >
            {theme === 'light' ? <Moon size={20} /> : <Sun size={20} />}
          </button>
        </header>

        <div className="flex-1 overflow-y-auto scroll-smooth pb-32">
          <article className="max-w-3xl mx-auto px-6 py-12 md:py-20">
            {chapter.blocks?.map((block, idx) => {
              switch (block.type) {
                case 'part':
                  return (
                    <div key={idx} className="mb-4 text-amber-600 dark:text-amber-500 font-bold tracking-widest uppercase text-sm">
                      {block.text}
                    </div>
                  );
                case 'h1':
                  return (
                    <h1 key={idx} className="text-4xl md:text-5xl font-bold text-slate-900 dark:text-white mb-10 font-serif leading-tight whitespace-pre-line">
                      {block.text}
                    </h1>
                  );
                case 'h2':
                  return (
                    <h2 key={idx} className="text-2xl md:text-3xl font-bold text-slate-900 dark:text-white mt-16 mb-6 font-serif">
                      {block.text}
                    </h2>
                  );
                case 'h3':
                  return (
                    <h3 key={idx} className="text-xl font-bold text-slate-800 dark:text-slate-200 mt-10 mb-4">
                      {block.text}
                    </h3>
                  );
                case 'p':
                  return (
                    <p key={idx} className="text-lg md:text-xl leading-relaxed mb-6 font-serif text-slate-700 dark:text-slate-300 whitespace-pre-line">
                      {block.text}
                    </p>
                  );
                case 'quote':
                  return (
                    <blockquote key={idx} className="my-12 pl-6 border-l-4 border-amber-500 text-2xl font-serif italic text-slate-800 dark:text-slate-200 font-light leading-relaxed">
                      "{block.text}"
                    </blockquote>
                  );
                case 'ul':
                  return (
                    <ul key={idx} className="space-y-4 my-6 pl-4">
                      {block.items.map((item, i) => (
                        <li key={i} className="flex gap-4 items-start text-lg md:text-xl leading-relaxed font-serif text-slate-700 dark:text-slate-300">
                          <span className="w-2 h-2 mt-2.5 rounded-full bg-amber-500 flex-shrink-0"></span>
                          <span>{item}</span>
                        </li>
                      ))}
                    </ul>
                  );
                case 'figure':
                  return <FigureBlock key={idx} {...block} />;
                case 'pushback':
                  return <PushbackCard key={idx} {...block} />;
                case 'worksheet':
                  return <InteractiveWorksheet key={idx} {...block} />;
                default:
                  return null;
              }
            })}

            <div className="mt-20 pt-10 border-t border-slate-200 dark:border-slate-800 flex justify-between items-center">
              {currentChapterIdx > 1 ? (
                <button 
                  onClick={() => goToChapter(currentChapterIdx - 1)}
                  className="flex items-center gap-2 text-slate-500 hover:text-slate-900 dark:hover:text-white transition-colors font-medium"
                >
                  <ChevronLeft size={20} /> Previous
                </button>
              ) : <div></div>}
              
              {currentChapterIdx < bookData.length - 1 && (
                <button 
                  onClick={() => goToChapter(currentChapterIdx + 1)}
                  className="flex items-center gap-2 text-amber-600 dark:text-amber-500 hover:text-amber-700 dark:hover:text-amber-400 transition-colors font-bold uppercase tracking-wider"
                >
                  Next Chapter <ChevronRight size={20} />
                </button>
              )}
            </div>
          </article>
        </div>
      </main>
    </div>
  );
}
